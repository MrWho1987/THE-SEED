<UserControl x:Class="Seed.Dashboard.Controls.BrainTopologyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SeedBackgroundBrush}"
             ClipToBounds="True"
             MouseWheel="OnMouseWheel"
             MouseDown="OnMouseDown"
             MouseMove="OnMouseMove"
             MouseUp="OnMouseUp"
             MouseLeave="OnMouseLeave">
    <Border Background="{StaticResource SeedBackgroundBrush}" ClipToBounds="True">
        <Canvas x:Name="RootCanvas" Background="Transparent" SnapsToDevicePixels="True" />
    </Border>
</UserControl>
