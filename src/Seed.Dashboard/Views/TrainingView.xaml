<UserControl x:Class="Seed.Dashboard.Views.TrainingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:conv="clr-namespace:Seed.Dashboard.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="280" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="260" />
        </Grid.RowDefinitions>

        <!-- ═══ LEFT CONTROL PANEL ═══ -->
        <Border Grid.Column="0" Grid.RowSpan="3" Background="{StaticResource SeedSurfaceBrush}"
                BorderBrush="{StaticResource SeedSurfaceElevatedBrush}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                <StackPanel>

                    <!-- Config -->
                    <TextBlock Text="CONFIGURATION" FontSize="10" FontWeight="Bold"                               Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,8" />

                    <ComboBox ItemsSource="{Binding ConfigItems}" SelectedValuePath="FullPath"
                              SelectedValue="{Binding SelectedConfig}" DisplayMemberPath="DisplayName"
                              Style="{StaticResource SeedComboBox}" Margin="0,0,0,12" />

                    <Border Background="{StaticResource SeedSurfaceElevatedBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Population" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConfigPopulation}" Style="{StaticResource MetricValue}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Generations" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ConfigGenerations}" Style="{StaticResource MetricValue}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Eval Window" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ConfigEvalWindow}" Style="{StaticResource MetricValue}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Run Seed" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ConfigSeed}" Style="{StaticResource MetricValue}" />
                        </Grid>
                    </Border>

                    <!-- Actions -->
                    <TextBlock Text="ACTIONS" FontSize="10" FontWeight="Bold"                               Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,8" />

                    <Button Style="{StaticResource PrimaryButton}" Padding="0,12" Margin="0,0,0,6"
                            Command="{Binding StartTrainingCommand}">
                        <TextBlock Text="Start Training" Foreground="#0B0E13" FontWeight="SemiBold" />
                    </Button>
                    <Button Style="{StaticResource DangerButton}" Padding="0,8" Margin="0,0,0,6"
                            Command="{Binding StopTrainingCommand}">
                        <TextBlock Text="Stop" Foreground="{StaticResource SeedWarningBrush}" />
                    </Button>

                    <!-- Progress (visible when running) -->
                    <StackPanel Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}" Margin="0,8,0,0">
                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" Margin="0,0,0,6"
                                     Foreground="{StaticResource SeedPrimaryBrush}"
                                     Background="{StaticResource SeedSurfaceElevatedBrush}" />
                        <DockPanel Margin="0,0,0,2">
                            <TextBlock Text="{Binding CurrentGen, StringFormat='Gen {0}'}"
                                       Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding TotalGens, StringFormat='/ {0}'}"
                                       Style="{StaticResource MetricLabel}" HorizontalAlignment="Right" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="{Binding ElapsedTime, StringFormat='Elapsed: {0}'}"
                                       Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding EtaTime, StringFormat='ETA: {0}'}"
                                       Style="{StaticResource MetricLabel}" HorizontalAlignment="Right" />
                        </DockPanel>
                    </StackPanel>

                    <!-- Current Best -->
                    <TextBlock Text="CURRENT BEST" FontSize="10" FontWeight="Bold"                               Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,20,0,8" />

                    <Border Background="{StaticResource SeedSurfaceElevatedBrush}" CornerRadius="6" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition /><RowDefinition /><RowDefinition />
                                <RowDefinition /><RowDefinition /><RowDefinition />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Fitness" Style="{StaticResource MetricLabel}"
                                       ToolTip="Overall performance score. Higher is better." />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BestFitness}" Style="{StaticResource MetricValue}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Sharpe" Style="{StaticResource MetricLabel}"
                                       ToolTip="Return per unit of risk. Above 2.0 is excellent." />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BestSharpe}" Style="{StaticResource MetricValue}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Return" Style="{StaticResource MetricLabel}"
                                       ToolTip="Total return on simulated capital." />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BestReturn}" Style="{StaticResource MetricValue}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Trades" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding BestTrades}" Style="{StaticResource MetricValue}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Win Rate" Style="{StaticResource MetricLabel}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding BestWinRate}" Style="{StaticResource MetricValue}" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Substrate" Style="{StaticResource MetricLabel}"
                                       ToolTip="Brain dimensions (width x height x layers)." />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding BestSubstrate}" Style="{StaticResource MetricValue}" />
                        </Grid>
                    </Border>

                    <!-- Walk-Forward -->
                    <TextBlock Text="WALK-FORWARD" FontSize="10" FontWeight="Bold"                               Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,20,0,8" />

                    <Border Background="{StaticResource SeedSurfaceElevatedBrush}" CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <DockPanel Margin="0,1">
                                <TextBlock Text="Passes" Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding WalkForwardPasses}" Style="{StaticResource MetricValue}"
                                           Foreground="{StaticResource SeedPrimaryBrush}" HorizontalAlignment="Right" />
                            </DockPanel>
                            <DockPanel Margin="0,1">
                                <TextBlock Text="Offset" Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding WalkForwardOffset}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right" />
                            </DockPanel>
                            <DockPanel Margin="0,1">
                                <TextBlock Text="Stall" Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding StallCounter}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right" />
                            </DockPanel>
                            <DockPanel Margin="0,1">
                                <TextBlock Text="Last" Style="{StaticResource MetricLabel}" />
                                <TextBlock Text="{Binding LastValidation}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══ FITNESS CHART (center) ═══ -->
        <Grid Grid.Column="1" Grid.Row="0" Margin="4,4,4,0">
            <Border Background="{StaticResource SeedSurfaceBrush}" CornerRadius="8" Padding="8">
                <oxy:PlotView Model="{Binding FitnessPlotModel}" Background="Transparent" />
            </Border>
            <TextBlock Text="Start training to see fitness evolution"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="15" Foreground="{StaticResource SeedTextSecondaryBrush}" Opacity="0.6"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- ═══ TRAINING COMPLETE BANNER ═══ -->
        <Border Grid.Column="1" Grid.Row="1" Margin="4,4,4,0"
                Background="{StaticResource SeedSurfaceBrush}" CornerRadius="8"
                BorderBrush="{StaticResource SeedPrimaryBrush}" BorderThickness="1"
                Padding="16,10"
                Visibility="{Binding IsComplete, Converter={StaticResource BoolVis}}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Training Complete" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource SeedPrimaryBrush}" />
                    <TextBlock Foreground="{StaticResource SeedTextSecondaryBrush}" FontSize="12">
                        <Run Text="{Binding CurrentGen, Mode=OneWay, StringFormat='{}{0} generations.'}" />
                        <Run Text=" Best Sharpe: " /><Run Text="{Binding BestSharpe, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ GENERATION LOG ═══ -->
        <Border Grid.Column="1" Grid.Row="2" Margin="4,4,4,4"
                Background="{StaticResource SeedSurfaceBrush}" CornerRadius="8" Padding="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="GENERATION LOG" FontSize="10" FontWeight="Bold"                           Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="12,8,0,0" />
                <DataGrid Grid.Row="1" ItemsSource="{Binding GenerationLog}"
                           Style="{StaticResource SeedDataGrid}"
                           ColumnHeaderStyle="{StaticResource SeedDataGridColumnHeader}"
                           CellStyle="{StaticResource SeedDataGridCell}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Gen" Binding="{Binding Gen}" Width="55" />
                        <DataGridTextColumn Header="Best" Binding="{Binding Best, StringFormat=F2}" Width="80" />
                        <DataGridTextColumn Header="Mean" Binding="{Binding Mean, StringFormat=F2}" Width="80" />
                        <DataGridTextColumn Header="Sharpe" Binding="{Binding Sharpe, StringFormat=F2}" Width="75" />
                        <DataGridTextColumn Header="Return" Binding="{Binding Return}" Width="85" />
                        <DataGridTextColumn Header="WinRate" Binding="{Binding WinRate}" Width="70" />
                        <DataGridTextColumn Header="Trades" Binding="{Binding Trades}" Width="65" />
                        <DataGridTextColumn Header="Species" Binding="{Binding Species}" Width="65" />
                        <DataGridTextColumn Header="ValFit" Binding="{Binding ValFit}" Width="75" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
