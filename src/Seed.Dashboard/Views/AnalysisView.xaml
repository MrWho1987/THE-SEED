<UserControl x:Class="Seed.Dashboard.Views.AnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:conv="clr-namespace:Seed.Dashboard.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Setup Panel -->
        <Border Grid.Column="0" Background="{StaticResource SeedSurfaceBrush}"
                BorderBrush="{StaticResource SeedSurfaceElevatedBrush}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="ANALYSIS SETUP" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,10" />

                    <TextBlock Text="Genome" Style="{StaticResource MetricLabel}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableGenomes}" SelectedItem="{Binding SelectedGenome}"
                              Style="{StaticResource SeedComboBox}" Margin="0,0,0,16" />

                    <TextBlock Text="MODE" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,8" />

                    <RadioButton GroupName="Mode" IsChecked="True" Margin="0,2"
                                 Foreground="{StaticResource SeedTextPrimaryBrush}"
                                 Command="{Binding SelectModeCommand}" CommandParameter="Compare">
                        <StackPanel Margin="4,0">
                            <TextBlock Text="Compare" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource SeedTextPrimaryBrush}" />
                            <TextBlock Text="Evolved agent vs 4 baseline strategies"
                                       FontSize="10" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Mode" Margin="0,2"
                                 Foreground="{StaticResource SeedTextPrimaryBrush}"
                                 Command="{Binding SelectModeCommand}" CommandParameter="Ablation">
                        <StackPanel Margin="4,0">
                            <TextBlock Text="Ablation" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource SeedTextPrimaryBrush}" />
                            <TextBlock Text="Which brain components matter?"
                                       FontSize="10" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Mode" Margin="0,2"
                                 Foreground="{StaticResource SeedTextPrimaryBrush}"
                                 Command="{Binding SelectModeCommand}" CommandParameter="StressTest">
                        <StackPanel Margin="4,0">
                            <TextBlock Text="Stress Test" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource SeedTextPrimaryBrush}" />
                            <TextBlock Text="Handle 2x-5x higher costs?"
                                       FontSize="10" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Mode" Margin="0,2"
                                 Foreground="{StaticResource SeedTextPrimaryBrush}"
                                 Command="{Binding SelectModeCommand}" CommandParameter="MonteCarlo">
                        <StackPanel Margin="4,0">
                            <TextBlock Text="Monte Carlo" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource SeedTextPrimaryBrush}" />
                            <TextBlock Text="Bootstrap 10K confidence intervals"
                                       FontSize="10" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Mode" Margin="0,2"
                                 Foreground="{StaticResource SeedTextPrimaryBrush}"
                                 Command="{Binding SelectModeCommand}" CommandParameter="NeuroAblation">
                        <StackPanel Margin="4,0">
                            <TextBlock Text="Neuro Ablation" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource SeedTextPrimaryBrush}" />
                            <TextBlock Text="Which learning channels matter?"
                                       FontSize="10" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                        </StackPanel>
                    </RadioButton>

                    <!-- Run / Stop buttons -->
                    <Button Style="{StaticResource PrimaryButton}" Padding="0,10" Margin="0,16,0,0"
                            Command="{Binding RunAnalysisCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}, ConverterParameter=Invert}">
                        <TextBlock Text="Run Analysis" Foreground="{StaticResource SeedOnPrimaryBrush}"
                                   FontWeight="SemiBold" FontSize="13" />
                    </Button>
                    <Button Style="{StaticResource DangerButton}" Padding="0,10" Margin="0,16,0,0"
                            Command="{Binding StopAnalysisCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="Stop Analysis" FontWeight="SemiBold" FontSize="13"
                                   Foreground="White" />
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Results Panel -->
        <Grid Grid.Column="1" Margin="12">

            <!-- Empty state (no results yet) -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding HasResults, Converter={StaticResource BoolVis}, ConverterParameter=Invert}">
                <materialDesign:PackIcon Kind="Microscope" Width="48" Height="48"
                                        Foreground="{StaticResource SeedTextSecondaryBrush}"
                                        HorizontalAlignment="Center" Opacity="0.4" />
                <TextBlock Text="Select a mode and run analysis" FontSize="15" Margin="0,12,0,0"
                           Foreground="{StaticResource SeedTextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Real engine results with charts and interpretation"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{StaticResource SeedTextSecondaryBrush}"
                           HorizontalAlignment="Center" Opacity="0.6" />
            </StackPanel>

            <!-- Results (visible after analysis completes) -->
            <Grid Visibility="{Binding HasResults, Converter={StaticResource BoolVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" MinHeight="200" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Chart -->
                <oxy:PlotView Grid.Row="0" Model="{Binding ResultsPlotModel}"
                              Background="Transparent" />

                <!-- Console output -->
                <Border Grid.Row="1" Background="{StaticResource SeedSurfaceBrush}"
                        CornerRadius="6" Margin="0,8" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                        <TextBlock Text="{Binding ResultText}"
                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                   Foreground="{StaticResource SeedTextPrimaryBrush}"
                                   FontSize="11" />
                    </ScrollViewer>
                </Border>

                <!-- Interpretation -->
                <Border Grid.Row="2" Background="{StaticResource SeedSurfaceElevatedBrush}"
                        CornerRadius="6" Padding="12" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="INTERPRETATION" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding InterpretationText}" TextWrapping="Wrap"
                                   Foreground="{StaticResource SeedTextPrimaryBrush}" FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Loading overlay -->
            <Grid Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"
                  Background="#CC0B0E13">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200"
                                 Foreground="{StaticResource SeedPrimaryBrush}" />
                    <TextBlock Text="Running analysis engine..." FontSize="14"
                               Margin="0,14,0,0"
                               Foreground="{StaticResource SeedTextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="This may take a few minutes depending on the mode"
                               FontSize="11" Margin="0,4,0,0"
                               Foreground="{StaticResource SeedTextSecondaryBrush}"
                               HorizontalAlignment="Center" Opacity="0.6" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
