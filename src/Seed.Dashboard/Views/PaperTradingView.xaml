<UserControl x:Class="Seed.Dashboard.Views.PaperTradingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:conv="clr-namespace:Seed.Dashboard.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:PnlColorConverter x:Key="PnlColor" />
        <conv:PnlArrowConverter x:Key="PnlArrow" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{StaticResource SeedSurfaceBrush}"
                BorderBrush="{StaticResource SeedSurfaceElevatedBrush}" BorderThickness="0,0,0,1"
                Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Genome:" Foreground="{StaticResource SeedTextSecondaryBrush}" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding AvailableGenomes}" SelectedItem="{Binding SelectedGenome}"
                          Style="{StaticResource SeedComboBox}" Width="320" />
                <Button Style="{StaticResource PrimaryButton}" Padding="18,8" Margin="12,0,6,0"
                        Command="{Binding StartPaperTradingCommand}">
                    <TextBlock Text="Start Paper Trading" Foreground="{StaticResource SeedOnPrimaryBrush}" FontWeight="SemiBold" FontSize="12" />
                </Button>
                <Button Style="{StaticResource DangerButton}" Padding="14,8" Margin="4,0"
                        Command="{Binding StopPaperTradingCommand}">
                    <TextBlock Text="Stop" Foreground="{StaticResource SeedWarningBrush}" FontSize="12" />
                </Button>
                <Border Margin="12,0,0,0" Padding="10,5" CornerRadius="4" VerticalAlignment="Center"
                        Background="#22F59E0B"
                        Visibility="{Binding IsWarmup, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="Warming up — indicators need ~24h" FontSize="11"
                               Foreground="{StaticResource SeedCautionBrush}" />
                </Border>
                <TextBlock Text="{Binding SessionDuration, StringFormat='Running: {0}'}" Margin="16,0,0,0"
                           Foreground="{StaticResource SeedTextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"
                           Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}" />
            </StackPanel>
        </Border>

        <!-- Chart + Portfolio -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Price Chart -->
            <Border Grid.Column="0" Margin="4,4,0,4" Background="{StaticResource SeedSurfaceBrush}"
                    CornerRadius="8" Padding="8">
                <oxy:PlotView Model="{Binding PricePlotModel}" Background="Transparent" />
            </Border>

            <!-- Portfolio Panel -->
            <Border Grid.Column="1" Background="{StaticResource SeedSurfaceBrush}"
                    BorderBrush="{StaticResource SeedSurfaceElevatedBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>
                        <!-- Equity -->
                        <TextBlock Text="PORTFOLIO" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="{Binding EquityText}" Style="{StaticResource HeroMetric}"
                                       Foreground="{Binding TotalPnl, Converter={StaticResource PnlColor}}" />
                            <TextBlock Text="{Binding TotalPnl, Converter={StaticResource PnlArrow}}" FontSize="18"
                                       Foreground="{Binding TotalPnl, Converter={StaticResource PnlColor}}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock FontSize="12" Margin="0,0,0,14"
                                   Foreground="{Binding TotalPnl, Converter={StaticResource PnlColor}}">
                            <Run Text="{Binding TotalPnlText, Mode=OneWay}" />
                            <Run Text=" (" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                            <Run Text="{Binding ChangePctText, Mode=OneWay}" />
                            <Run Text=" )" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                        </TextBlock>

                        <!-- Position -->
                        <TextBlock Text="POSITION" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,6" />
                        <Border Background="{StaticResource SeedSurfaceElevatedBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                            <StackPanel>
                                <Border Padding="8,3" CornerRadius="4" HorizontalAlignment="Left" Margin="0,0,0,8"
                                        Background="{StaticResource SeedSurfaceElevatedBrush}"
                                        BorderBrush="{StaticResource SeedPrimaryBrush}" BorderThickness="1">
                                    <TextBlock Text="{Binding Position}" FontWeight="Bold" FontSize="12"
                                               Foreground="{StaticResource SeedTextPrimaryBrush}" />
                                </Border>
                                <DockPanel Margin="0,2">
                                    <TextBlock Text="Price" Style="{StaticResource MetricLabel}" />
                                    <TextBlock Text="{Binding PriceText}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right" />
                                </DockPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock Text="Unrl P&amp;L" Style="{StaticResource MetricLabel}" />
                                    <TextBlock Text="{Binding UnrealizedText}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right"
                                               Foreground="{Binding UnrealizedPnl, Converter={StaticResource PnlColor}}" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Performance -->
                        <TextBlock Text="PERFORMANCE" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,6" />
                        <Border Background="{StaticResource SeedSurfaceElevatedBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                            <StackPanel>
                                <DockPanel Margin="0,2"><TextBlock Text="Total P&amp;L" Style="{StaticResource MetricLabel}"
                                           ToolTip="Total realized profit and loss from all closed trades." />
                                    <TextBlock Text="{Binding TotalPnlText}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right"
                                               Foreground="{Binding TotalPnl, Converter={StaticResource PnlColor}}" /></DockPanel>
                                <DockPanel Margin="0,2"><TextBlock Text="Win Rate" Style="{StaticResource MetricLabel}" ToolTip="Percentage of trades that made money." />
                                    <TextBlock Text="{Binding WinRateText}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right" /></DockPanel>
                                <DockPanel Margin="0,2"><TextBlock Text="Rolling Sharpe" Style="{StaticResource MetricLabel}" ToolTip="Sharpe over last 100 ticks." />
                                    <TextBlock Text="{Binding RollingSharpeText}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right" /></DockPanel>
                                <DockPanel Margin="0,2"><TextBlock Text="Rolling DD" Style="{StaticResource MetricLabel}" ToolTip="Max drawdown in last 100 ticks." />
                                    <TextBlock Text="{Binding RollingDrawdownText}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right" /></DockPanel>
                                <DockPanel Margin="0,2"><TextBlock Text="Trades" Style="{StaticResource MetricLabel}"
                                           ToolTip="Total number of completed trades in this session." />
                                    <TextBlock Text="{Binding TotalTrades}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right" /></DockPanel>
                                <DockPanel Margin="0,2"><TextBlock Text="Avg P&amp;L" Style="{StaticResource MetricLabel}"
                                           ToolTip="Average profit/loss per trade." />
                                    <TextBlock Text="{Binding AvgPnlText}" Style="{StaticResource MetricValue}" HorizontalAlignment="Right" /></DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Risk -->
                        <TextBlock Text="RISK" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,6" />
                        <Border Background="{StaticResource SeedSurfaceElevatedBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                             Fill="{StaticResource SeedPrimaryBrush}" />
                                    <TextBlock FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"
                                               Foreground="{StaticResource SeedPrimaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="SAFE" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding KillSwitch}" Value="True">
                                                        <Setter Property="Text" Value="KILL SWITCH TRIGGERED" />
                                                        <Setter Property="Foreground" Value="{StaticResource SeedWarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{Binding MaxDrawdownText, StringFormat='Max Drawdown: {0}'}"
                                           Style="{StaticResource MetricLabel}" Margin="0,0,0,6"
                                           ToolTip="Largest peak-to-trough decline. Kill switch at 15%." />
                                <ProgressBar Value="{Binding DrawdownProgress}" Maximum="100" Height="4"
                                             Foreground="{StaticResource SeedCautionBrush}"
                                             Background="{StaticResource SeedSurfaceBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Equity Curve -->
                        <TextBlock Text="EQUITY CURVE" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,6" />
                        <Border Background="{StaticResource SeedSurfaceElevatedBrush}" CornerRadius="6" Padding="4">
                            <oxy:PlotView Model="{Binding EquityPlotModel}" Height="100" Background="Transparent" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Trade History -->
        <Border Grid.Row="2" Margin="4,0,4,4" Background="{StaticResource SeedSurfaceBrush}" CornerRadius="8" Padding="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,6,0,0">
                    <TextBlock Text="TRADE HISTORY" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource SeedTextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalTrades, StringFormat=' ({0} trades)'}"
                               Foreground="{StaticResource SeedTextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding TradeHistory}"
                           Style="{StaticResource SeedDataGrid}"
                           ColumnHeaderStyle="{StaticResource SeedDataGridColumnHeader}"
                           CellStyle="{StaticResource SeedDataGridCell}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Number}" Width="45" />
                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="85" />
                        <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="65" />
                        <DataGridTextColumn Header="Entry" Binding="{Binding Entry, StringFormat=N2}" Width="100" />
                        <DataGridTextColumn Header="Exit" Binding="{Binding Exit, StringFormat=N2}" Width="100" />
                        <DataGridTextColumn Header="Size" Binding="{Binding Size, StringFormat=F6}" Width="90" />
                        <DataGridTextColumn Header="P&amp;L" Binding="{Binding Pnl, StringFormat=N2}" Width="90" />
                        <DataGridTextColumn Header="Fee" Binding="{Binding Fee, StringFormat=N2}" Width="70" />
                        <DataGridTextColumn Header="Hold" Binding="{Binding HoldTicks}" Width="60" />
                        <DataGridTextColumn Header="P&amp;L%" Binding="{Binding PnlPct}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
