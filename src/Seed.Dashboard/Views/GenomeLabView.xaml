<UserControl x:Class="Seed.Dashboard.Views.GenomeLabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:Seed.Dashboard.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Browser -->
        <Border Grid.Column="0" Background="{StaticResource SeedSurfaceBrush}"
                BorderBrush="{StaticResource SeedSurfaceElevatedBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="14,12">
                <TextBlock DockPanel.Dock="Top" Text="GENOME BROWSER" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,10" />
                <TextBox DockPanel.Dock="Top" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,7" FontSize="12" Margin="0,0,0,8"
                         Background="{StaticResource SeedSurfaceElevatedBrush}"
                         Foreground="{StaticResource SeedTextPrimaryBrush}"
                         BorderBrush="{StaticResource SeedSurfaceElevatedBrush}"
                         materialDesign:HintAssist.Hint="Search genomes..." />
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}"
                              Style="{StaticResource SeedComboBox}" Width="180" />
                    <Button Style="{StaticResource ActionCardButton}" Padding="8,6" Margin="6,0,0,0"
                            HorizontalAlignment="Right" Command="{Binding RefreshListCommand}">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                Foreground="{StaticResource SeedTextSecondaryBrush}" />
                    </Button>
                </DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Browse by output folder. Right-click a genome for actions."
                           FontSize="10" Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,8" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DirectoryTree}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding FolderLabel}" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{StaticResource SeedPrimaryBrush}" Margin="0,4,0,4" />
                                    <ListBox ItemsSource="{Binding Files}"
                                             SelectedItem="{Binding DataContext.SelectedGenome, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             Background="Transparent" BorderThickness="0" Padding="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" Margin="0,1" CornerRadius="4"
                                                        Background="Transparent" Cursor="Hand">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="Medium"
                                                                   Foreground="{StaticResource SeedTextPrimaryBrush}" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <Border Padding="4,1" CornerRadius="3" Margin="0,0,6,0"
                                                                    Background="{StaticResource SeedSurfaceElevatedBrush}">
                                                                <TextBlock Text="{Binding Category}" FontSize="9"
                                                                           Foreground="{StaticResource SeedTextSecondaryBrush}" />
                                                            </Border>
                                                            <TextBlock Text="{Binding Modified, StringFormat='{}{0:M/d/yyyy h:mm tt}'}" FontSize="10"
                                                                       Foreground="{StaticResource SeedTextSecondaryBrush}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Right Inspector -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel MaxWidth="800">
                <!-- Action Bar -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Style="{StaticResource PrimaryButton}" Padding="16,8" Margin="0,0,8,0"
                            Command="{Binding DeployToPaperCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Play" Width="16" Height="16" Foreground="{StaticResource SeedOnPrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="Deploy to paper" Foreground="{StaticResource SeedOnPrimaryBrush}" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ActionCardButton}" Padding="16,8" Margin="0,0,8,0"
                            Command="{Binding RunAnalysisCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBar" Width="16" Height="16" Foreground="{StaticResource SeedTextPrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="Run analysis" Foreground="{StaticResource SeedTextPrimaryBrush}" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ActionCardButton}" Padding="16,8"
                            Command="{Binding RefreshListCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Foreground="{StaticResource SeedTextPrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="Refresh list" Foreground="{StaticResource SeedTextPrimaryBrush}" FontSize="12" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Identity -->
                <TextBlock Text="IDENTITY" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,8" />
                <Border Background="{StaticResource SeedSurfaceBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,3">
                            <TextBlock Text="Genome ID" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding GenomeIdText}" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,3">
                            <TextBlock Text="Category" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding InspectorCategory}" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,3">
                            <TextBlock Text="Source file" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding InspectorSourcePath}" Style="{StaticResource MetricValue}" FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,3">
                            <TextBlock Text="Last modified" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding InspectorModifiedText}" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Complexity -->
                <TextBlock Text="COMPLEXITY" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,0,0,8" />
                <Border Background="{StaticResource SeedSurfaceBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,3">
                            <TextBlock Text="CPPN nodes" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding CppnNodes}" Style="{StaticResource MetricValue}" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,3">
                            <TextBlock Text="CPPN connections" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding CppnConnections}" Style="{StaticResource MetricValue}" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,3">
                            <TextBlock Text="Brain neurons" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding BrainNodes}" Style="{StaticResource MetricValue}" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,3">
                            <TextBlock Text="Synapses (edges)" Style="{StaticResource MetricLabel}" />
                            <TextBlock Text="{Binding BrainEdges}" Style="{StaticResource MetricValue}" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,3">
                            <TextBlock Text="Substrate (w × h × layers)" Style="{StaticResource MetricLabel}" />
                            <TextBlock Style="{StaticResource MetricValue}" FontSize="18" FontWeight="SemiBold">
                                <Run Text="{Binding SubstrateWidth, Mode=OneWay}" />
                                <Run Text=" × " />
                                <Run Text="{Binding SubstrateHeight, Mode=OneWay}" />
                                <Run Text=" × " />
                                <Run Text="{Binding SubstrateLayers, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
