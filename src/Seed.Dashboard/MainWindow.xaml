<Window x:Class="Seed.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:Seed.Dashboard.ViewModels"
        xmlns:views="clr-namespace:Seed.Dashboard.Views"
        xmlns:conv="clr-namespace:Seed.Dashboard.Converters"
        Title="The Seed" Height="900" Width="1440"
        WindowState="Maximized"
        Icon="seed_icon.png"
        Background="{StaticResource SeedBackgroundBrush}"
        Foreground="{StaticResource SeedTextPrimaryBrush}"
        FontFamily="Segoe UI"
        TextElement.FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0"
                      ResizeBorderThickness="6" CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+1" Command="{Binding NavigateToCommand}" CommandParameter="Home" />
        <KeyBinding Gesture="Ctrl+2" Command="{Binding NavigateToCommand}" CommandParameter="Train" />
        <KeyBinding Gesture="Ctrl+3" Command="{Binding NavigateToCommand}" CommandParameter="Trade" />
        <KeyBinding Gesture="Ctrl+4" Command="{Binding NavigateToCommand}" CommandParameter="Genomes" />
        <KeyBinding Gesture="Ctrl+5" Command="{Binding NavigateToCommand}" CommandParameter="Analyze" />
        <KeyBinding Gesture="Ctrl+6" Command="{Binding NavigateToCommand}" CommandParameter="Settings" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- Left Navigation Rail -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                Background="{StaticResource SeedSurfaceBrush}"
                BorderBrush="{StaticResource SeedSurfaceElevatedBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,8,0,0">
                <RadioButton Style="{StaticResource NavButton}" Tag="Home" IsChecked="True"
                             Command="{Binding NavigateToCommand}" CommandParameter="Home">
                    <materialDesign:PackIcon Kind="Home" Width="24" Height="24" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                </RadioButton>
                <RadioButton Style="{StaticResource NavButton}" Tag="Train"
                             Command="{Binding NavigateToCommand}" CommandParameter="Train">
                    <materialDesign:PackIcon Kind="Flask" Width="24" Height="24" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                </RadioButton>
                <RadioButton Style="{StaticResource NavButton}" Tag="Trade"
                             Command="{Binding NavigateToCommand}" CommandParameter="Trade">
                    <materialDesign:PackIcon Kind="ChartLine" Width="24" Height="24" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                </RadioButton>
                <RadioButton Style="{StaticResource NavButton}" Tag="Genomes"
                             Command="{Binding NavigateToCommand}" CommandParameter="Genomes">
                    <materialDesign:PackIcon Kind="Dna" Width="24" Height="24" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                </RadioButton>
                <RadioButton Style="{StaticResource NavButton}" Tag="Analyze"
                             Command="{Binding NavigateToCommand}" CommandParameter="Analyze">
                    <materialDesign:PackIcon Kind="Microscope" Width="24" Height="24" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                </RadioButton>
                <RadioButton Style="{StaticResource NavButton}" Tag="Settings"
                             Command="{Binding NavigateToCommand}" CommandParameter="Settings">
                    <materialDesign:PackIcon Kind="Cog" Width="24" Height="24" Foreground="{StaticResource SeedTextSecondaryBrush}" />
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- Custom Title Bar / Session Bar (serves as WindowChrome caption) -->
        <Border Grid.Column="1" Grid.Row="0" Background="{StaticResource SeedSurfaceBrush}"
                BorderBrush="{StaticResource SeedSurfaceElevatedBrush}" BorderThickness="0,0,0,1">
            <DockPanel Margin="12,0,0,0">
                <!-- App branding (left) -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="seed_icon.png" Width="20" Height="20" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="THE SEED" FontWeight="Bold" FontSize="13"
                               Foreground="{StaticResource SeedPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0" />

                    <Border Style="{StaticResource SessionChip}"
                            Visibility="{Binding IsTrainingRunning, Converter={StaticResource BoolVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource SeedPrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TrainingSessionLabel}" FontSize="11"
                                       Foreground="{StaticResource SeedTextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SessionChip}"
                            Visibility="{Binding IsPaperRunning, Converter={StaticResource BoolVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource SeedInfoBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PaperSessionLabel}" FontSize="11"
                                       Foreground="{StaticResource SeedTextPrimaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="No active sessions" FontSize="11"
                               Foreground="{StaticResource SeedTextSecondaryBrush}" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsTrainingRunning}" Value="False" />
                                            <Condition Binding="{Binding IsPaperRunning}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Window control buttons (right, hit-testable over WindowChrome) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Width="46" Height="40"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Minimize">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"
                                                Foreground="{StaticResource SeedTextSecondaryBrush}" />
                    </Button>
                    <Button x:Name="BtnMaximize" Click="BtnMaximize_Click" Width="46" Height="40"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Maximize / Restore">
                        <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16"
                                                Foreground="{StaticResource SeedTextSecondaryBrush}" />
                    </Button>
                    <Button x:Name="BtnClose" Click="BtnClose_Click" Width="46" Height="40"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="Close">
                        <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16"
                                                Foreground="{StaticResource SeedTextSecondaryBrush}" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Grid.Row="1">
            <!-- Notification toasts overlay -->
            <ItemsControl ItemsSource="{Binding Notifications.ActiveToasts}"
                          HorizontalAlignment="Right" VerticalAlignment="Top"
                          Margin="0,8,16,0" Panel.ZIndex="100">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="12,8" CornerRadius="6" MinWidth="320" MaxWidth="420"
                                Background="{StaticResource SeedSurfaceElevatedBrush}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Opacity="0.4" ShadowDepth="4" />
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource SeedTextPrimaryBrush}" />
                                <TextBlock Text="{Binding Message}" FontSize="12" TextWrapping="Wrap"
                                           Foreground="{StaticResource SeedTextSecondaryBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- View pages -->
            <TabControl SelectedIndex="{Binding SelectedNavIndex}"
                        Background="Transparent" BorderThickness="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </Style>
                </TabControl.ItemContainerStyle>
                <TabItem><views:DashboardView DataContext="{Binding Dashboard}" /></TabItem>
                <TabItem><views:TrainingView DataContext="{Binding Training}" /></TabItem>
                <TabItem><views:PaperTradingView DataContext="{Binding PaperTrading}" /></TabItem>
                <TabItem><views:GenomeLabView DataContext="{Binding GenomeLab}" /></TabItem>
                <TabItem><views:AnalysisView DataContext="{Binding Analysis}" /></TabItem>
                <TabItem><views:SettingsView DataContext="{Binding Settings}" /></TabItem>
            </TabControl>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Column="1" Grid.Row="2" Background="{StaticResource SeedSurfaceBrush}"
                BorderBrush="{StaticResource SeedSurfaceElevatedBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="11"
                           Foreground="{StaticResource SeedTextSecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding BestFitnessText}" FontSize="11"
                           Foreground="{StaticResource SeedTextSecondaryBrush}" VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding ClockText}" FontSize="11"
                           Foreground="{StaticResource SeedTextSecondaryBrush}" VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</Window>
