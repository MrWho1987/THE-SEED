# User-specific config overrides (local configs with real API keys).
# Broad rule: ignore ALL market-config.*.json except the placeholder default.
config.json
market-config.*.json
!market-config.default.json

# Pipeline shared cache (downloaded market data)
pipeline_shared_cache/

# Cached market data
data_cache/

# Run outputs (checkpoints, heartbeats, trade logs)
# Root-anchored so archived copies under archive/baseline/ are still trackable.
/output/
/output_*/

# Archive: v2 reference. Override build-pattern ignores for archive/baseline/logs/
# (the [Ll]ogs/ pattern above is meant for bin/Debug/Logs, not our archived training logs).
# Sensitive phase/paper configs under archive/baseline/configs/ remain ignored via the
# market-config.*.json rules above (they contain API keys).
!archive/baseline/logs/
!archive/baseline/logs/*.log
!archive/Baseline/logs/
!archive/Baseline/logs/*.log
!archive/V1-PrefinalFix/logs/
!archive/V1-PrefinalFix/logs/*.log

# Pre-existing experimental archive dirs (from earlier sessions) — kept local only,
# not committed to remote. Baseline/ is the canonical v1 snapshot.
archive/configs-v1/
archive/v1-configs/
archive/v1-genomes/
archive/v1-training-data/

